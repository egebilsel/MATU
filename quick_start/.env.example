# Copy this file to quick_start/.env and fill in local values.
#
# OpenAI is only needed for the CAMEL/GPT log generation example.
OPENAI_API_KEY=

# Optional model choices for quick-start generation wrappers.
MATU_OPENAI_MODEL=GPT_4O
MATU_QWEN_MODEL=Qwen/Qwen2.5-7B-Instruct

# MATU uses Qwen3 embedding by default in both generation and standalone embedding.
MATU_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B

# Optional local Hugging Face cache/model directory.
MATU_MODEL_CACHE=

# Optional CP-2 rank range control.
MATU_MAX_RANK=50

